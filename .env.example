# ===========================================
# Videoflix Backend - Environment Configuration
# ===========================================
# Copy this file to .env: cp .env.example .env
# ===========================================

# Django
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgres://videoflix_user:videoflix_password@db:5432/videoflix

# Redis
REDIS_URL=redis://redis:6379/0

# Frontend URL (for E-Mail activation links)
# Change this to match your frontend port (5500, 5501, 5502, 5503, 5504, etc.)
FRONTEND_URL=http://127.0.0.1:5500

# Backend URL
BACKEND_URL=http://127.0.0.1:8000

# Superuser (auto-created on startup)
DJANGO_SUPERUSER_EMAIL=admin@videoflix.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Email - SMTP Configuration
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-password-or-app-password
DEFAULT_FROM_EMAIL=Videoflix <your-email@example.com>

# CORS - Allowed Origins (comma-separated, optional)
# Default: 5500-5504, 3000, 4200, 8080 are already allowed
# Add custom origins here if needed:
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://127.0.0.1:5501

# Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0