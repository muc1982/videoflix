# ===========================================
# Videoflix Backend - Environment Configuration
# ===========================================
# Copy this file to .env: cp .env.example .env
# ===========================================

# Django
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgres://videoflix_user:videoflix_password@db:5432/videoflix

# Redis
REDIS_URL=redis://redis:6379/0

# Frontend URL (for E-Mail links)
FRONTEND_URL=http://localhost:5500

# Backend URL
BACKEND_URL=http://localhost:8000

# Superuser
DJANGO_SUPERUSER_EMAIL=admin@videoflix.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Email (Mailhog)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=Videoflix <noreply@videoflix.com>

# Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
