# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must always have LF line endings (critical for Mac/Linux)
*.sh text eol=lf

# Python files should use LF
*.py text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.example text eol=lf

# Dockerfile
Dockerfile text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.webm binary
*.ts binary
